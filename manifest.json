{
  "name": "MD Tools",
  "short_name": "MD",
  "description": "Formular-App zur Erfassung von Bauleistungen.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#ffffff",
  "theme_color": "#5895a8",
  "file_handlers": [
    {
      "action": "LNR.html",
      "accept": {
        "application/octet-stream": [".lnr"]
      }
    },
	    {
      "action": "Std.html",
      "accept": {
        "application/octet-stream": [".stdz"]
      }
    },
    {
      "action": "LNZ.html",
      "accept": {
        "application/octet-stream": [".lnz"]
      }
    },
    {
      "action": "Kappenaufmaß.html",
      "accept": {
        "application/octet-stream": [".ka"]
      }
    }
  ],
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ] 
}










