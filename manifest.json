{
  "name": "MD Tools",
  "short_name": "MD",
  "description": "Formular-App zur Erfassung von Bauleistungen.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#ffffff",
  "theme_color": "#5895a8",
  "file_handlers": [
    { "action": "LNR.html", "accept": { "application/octet-stream": [".lnr"] } },
    { "action": "LNL.html", "accept": { "application/octet-stream": [".lnl"] } },
    { "action": "LNZ.html", "accept": { "application/octet-stream": [".lnz"] } },
    { "action": "Kappenaufmaß.html", "accept": { "application/octet-stream": [".ka"] } }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "shared_files",
          "accept": [".lnr", ".lnl", ".lnz", ".ka"]
        }
      ]
    }
  },
  "icons":
}











